    "python -m json.tool plugins/frontend-vibe-suite/data/component-libraries.json",
    "python -m json.tool plugins/frontend-vibe-suite/data/prompt-scenarios.json",
    "python -m json.tool plugins/frontend-vibe-suite/data/publisher-metadata.json",
    "python plugins/frontend-vibe-suite/scripts/release_preflight.py"
