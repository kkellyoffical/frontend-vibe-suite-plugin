  "adaptationMatrix": {
    "codex": {
      "supported": [
        "skills",
        "codex metadata",
        "bundle docs",
        "example assets"
      ],
      "caveats": [
        "Publisher metadata is repo-owned, not part of the base Codex bundle schema."
      ]
    },
    "openclaw": {
      "supported": [
        "skill roots",
        "MCP config",
        "OpenClaw hook-pack roots when present"
      ],
      "detectOnly": [
        "inline Codex app metadata beyond capability reporting"
      ],
      "caveats": [
        "Bundle installs are capability-mapped rather than native runtime modules.",
        "Compatible bundle behavior follows OpenClaw bundle support, not native plugin SDK guarantees."
      ]
    },
    "clawhub": {
      "supported": [
        "bundle-plugin publishing",
        "source-linked verification",
        "community channel discovery"
      ],
      "caveats": [
        "New releases can stay private or partially surfaced until automated scanning finishes.",
        "Publisher CLI behavior can vary by clawhub CLI version."
      ]
    }
  }
}
